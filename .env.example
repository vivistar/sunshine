# Copy to .env and adjust. All values are optional; sensible defaults are used.

# Public URL used to build survey/invitation links. Leave empty to auto-detect:
# on Render the platform's RENDER_EXTERNAL_URL is used automatically; otherwise
# it defaults to http://localhost:8000. Set it explicitly to pin a custom domain.
BASE_URL=

# Database (SQLAlchemy URL). Defaults to a local SQLite file.
DATABASE_URL=sqlite:///./sunshine.db

# --- Email (SMTP) ---
# Leave SMTP_HOST empty to run in console mode: emails are logged and written
# to ./dev_outbox/ instead of being sent. Great for local development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Sunshine Surveys <no-reply@sunshine.local>
# Use STARTTLS (true, typical for port 587) or implicit SSL (false, port 465).
SMTP_USE_TLS=true

# --- Admin authentication (browser login screen) ---
# A login screen at /login (backed by a signed session cookie) is enforced on
# the researcher/admin UI only when ADMIN_PASSWORD is set. Respondent survey
# links (/survey/<token>) are always public.
ADMIN_USER=admin
ADMIN_PASSWORD=
# Fail closed: when ADMIN_PASSWORD is empty the admin UI has no login, so the
# app REFUSES TO START unless you explicitly opt in here. Set this to true only
# for local development; never in production.
ALLOW_INSECURE_ADMIN=false
# Optional. Signs the session cookie; defaults to a value derived from
# ADMIN_PASSWORD. Set to a long random string to pin it explicitly (and to keep
# sessions stable across password changes).
SECRET_KEY=
